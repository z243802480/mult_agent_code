{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Event",
  "type": "object",
  "required": ["schema_version", "event_id", "run_id", "timestamp", "type", "actor", "summary"],
  "properties": {
    "schema_version": { "type": "string" },
    "event_id": { "type": "string" },
    "run_id": { "type": ["string", "null"] },
    "timestamp": { "type": "string" },
    "type": { "type": "string" },
    "actor": { "type": "string" },
    "summary": { "type": "string" },
    "data": { "type": "object" }
  }
}
