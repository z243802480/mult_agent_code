{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Task",
  "type": "object",
  "required": [
    "schema_version",
    "task_id",
    "title",
    "description",
    "status",
    "priority",
    "role",
    "depends_on",
    "acceptance",
    "allowed_tools",
    "expected_artifacts"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "task_id": { "type": "string" },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["backlog", "ready", "in_progress", "testing", "reviewing", "blocked", "done", "discarded"]
    },
    "priority": {
      "type": "string",
      "enum": ["critical", "high", "medium", "low"]
    },
    "role": { "type": "string" },
    "depends_on": { "type": "array", "items": { "type": "string" } },
    "acceptance": { "type": "array", "items": { "type": "string" } },
    "allowed_tools": { "type": "array", "items": { "type": "string" } },
    "expected_artifacts": { "type": "array", "items": { "type": "string" } },
    "task_kind": {
      "type": "string",
      "enum": ["diagnostic", "implementation", "verification", "research", "decision", "report", "ui"]
    },
    "expected_changed_files": { "type": "array", "items": { "type": "string" } },
    "verification_policy": {
      "type": "object",
      "properties": {
        "required": { "type": "boolean" },
        "allow_expected_failure": { "type": "boolean" },
        "commands": { "type": "array", "items": { "type": "string" } }
      }
    },
    "completion_contract": {
      "type": "object",
      "properties": {
        "requires_changed_artifact": { "type": "boolean" },
        "requires_verification": { "type": "boolean" },
        "allows_expected_failure": { "type": "boolean" }
      }
    },
    "assigned_agent_id": { "type": ["string", "null"] },
    "created_at": { "type": "string" },
    "updated_at": { "type": "string" },
    "quality": {
      "type": "object",
      "properties": {
        "clarity_score": { "type": "number" },
        "testability_score": { "type": "number" },
        "size_score": { "type": "number" },
        "artifact_score": { "type": "number" },
        "dependency_score": { "type": "number" },
        "risk_score": { "type": "number" },
        "passed": { "type": "boolean" }
      }
    },
    "notes": { "type": "string" }
  }
}
