{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MemoryEntry",
  "type": "object",
  "required": ["schema_version", "memory_id", "type", "content", "source", "tags", "confidence", "created_at"],
  "properties": {
    "schema_version": { "type": "string" },
    "memory_id": { "type": "string" },
    "type": {
      "type": "string",
      "enum": [
        "user_preference",
        "project_decision",
        "architecture_note",
        "research_claim",
        "experiment_lesson",
        "tool_knowledge",
        "failure_lesson"
      ]
    },
    "content": { "type": "string" },
    "source": { "type": "object" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "confidence": { "type": "number" },
    "created_at": { "type": "string" }
  }
}
