{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ExecutionAction",
  "type": "object",
  "required": ["schema_version", "task_id", "summary", "tool_calls", "verification"],
  "properties": {
    "schema_version": { "type": "string" },
    "task_id": { "type": "string" },
    "summary": { "type": "string" },
    "tool_calls": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["tool_name", "args"],
        "properties": {
          "tool_name": { "type": "string" },
          "args": { "type": "object" },
          "reason": { "type": "string" }
        }
      }
    },
    "verification": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["tool_name", "args"],
        "properties": {
          "tool_name": { "type": "string" },
          "args": { "type": "object" },
          "reason": { "type": "string" }
        }
      }
    },
    "completion_notes": { "type": "string" }
  }
}
